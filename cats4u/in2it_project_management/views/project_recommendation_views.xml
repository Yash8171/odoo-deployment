<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
         <!-- project.category tree view -->
        <record id="project_category_view_tree" model="ir.ui.view">
        <field name="name">project.category.view.tree</field>
        <field name="model">project.category</field>
        <field name="arch" type="xml">
            <list delete="1">
                <field name="name"/>
                <field name="category_id"/>
                <field name="category_description"/>
                <field name="for_efs"/>
            </list>
        </field>
        </record>

        <!-- project.category form view -->
        <record id="project_category_view_form" model="ir.ui.view">
            <field name="name">project.category.view.form</field>
            <field name="model">project.category</field>
            <field name="arch" type="xml">
                <form string="" edit="1" delete="1">
                    <header>
                        <button
                                name="action_preview_investigation_report"
                                class="btn-primary"
                                string="Preview Investigation Report"
                                icon="fa-eye"
                                type="object"
                        />
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_overarching_memo"
                                    type="object"
                                    string="Memo"
                                    class="oe_stat_button"
                                    icon="fa-sticky-note"
                                    >
                            </button>
                            <button name="action_open_rec_lines"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-list"
                                    invisible="completed_actions_count == all_actions_count and all_actions_count > 0"
                            >
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Action(s)</span>
                                    <span class="o_stat_value">
                                        <field name="completed_actions_count"/> / <field name="all_actions_count"/> Pending
                                    </span>
                                </div>
                            </button>
                            <button name="action_open_rec_lines"
                                    type="object"
                                    class="oe_stat_button text-success"
                                    icon="fa-check text-success"
                                    invisible="completed_actions_count != all_actions_count
                                        or all_actions_count == 0"
                            >
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_value">Action(s)</span>
                                    <span class="o_stat_value text-success">
                                        <field name="completed_actions_count"/> / <field name="all_actions_count"/> Completed
                                    </span>
                                </div>
                            </button>
                        </div>
                        <group string="Recommendation">
                            <group>
                                <field name="is_lead_investigator" invisible="1"/>
                                <field name="project_id" options="{'no_open':True}" readonly="1"/>
                                <field name="for_efs" readonly="1"/>
                                <field name="category_id" readonly="1" options="{'no_open': True}"/>
                                <field name="category_description" readonly="1"/>
                            </group>
                            <group>
                                <field name="case_id" options="{'no_open':True}"/>
                                <field name="assign_by"/>
                                <field name="assignment_date"/>
                                <field name="memo_status" invisible="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page name="annexure" string="Annexure">
                                <field name="annexure_ids" readonly="1">
                                    <list>
                                        <field name="serial_no"/>
                                        <field name="description" optional="hide"/>
                                        <field name="document_type_id"/>
                                        <field name="file_name"/>
                                        <field name="uploaded_by"/>
                                        <field name="uploaded_date"/>
                                        <field name="document_stores"/>
                                        <field name="document_stores_location" optional="hide"/>
                                        <field name="is_annexure"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="serial_no"/>
                                                    <field name="file" filename="file_name" widget="binary"/>
                                                    <field name="file_name" invisible="1"/>
                                                    <field name="document_type_id" options="{'no_create':True, 'no_edit':True, 'no_open':True}"/>
                                                    <field name="is_annexure"/>
                                                    <field name="document_stores"/>
                                                    <field name="document_stores_location" invisible="not document_stores"/>
                                                </group>
                                                <group>
                                                    <field name="description"/>
                                                    <field name="obtained_by"/>
                                                    <field name="obtained_from" options="{'no_create':True, 'no_edit':True, 'no_open':True}"/>
                                                    <field name="obtained_date"/>
                                                    <field name="uploaded_by" options="{'no_create':True, 'no_edit':True, 'no_open':True}"/>
                                                    <field name="uploaded_date"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>

                            <page string="🔎 Exhibits" name="exhibits">
                                <field name="exhibits_ids" nolabel="1" readonly="1">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="id" optional="hide"/>
                                        <field name="item_title" required="1"/>
                                        <field name="item_category" optional="show" required="1"/>
                                        <field name="quantity" optional="show" required="1"/>
                                        <field name="uom_id" optional="show" required="1" options="{'no_edit': True, 'no_create': True}"/>
                                        <field name="create_date" optional="hide" string="Date &amp; Time Received"/>
                                        <field name="source" optional="hide"/>
                                        <field name="recovery_location" optional="hide" required="1"/>
                                        <field name="associated_with" optional="hide" required="1"/>
                                        <field name="storage_location" optional="hide" required="1"/>
                                        <field name="current_custodian" optional="hide"/>
                                        <field name="status" optional="show" required="1"/>
                                        <field name="last_movement_date" optional="hide" force_save="1"/>
                                        <field name="doc_type_id" optional="show" options="{'no_edit': True, 'no_create': True}"/>
                                        <field name="attachment_ids" optional="hide" widget="many2many_binary"/>
                                        <field name="is_exhibit"/>
                                    </list>
                                    <form>
                                        <group>
                                            <group>
                                                <field name="item_title"/>
                                                <field name="item_category"/>
                                                <field name="quantity"/>
                                                <field name="uom_id" options="{'no_edit': True, 'no_create': True}"/>
                                                <field name="source"/>
                                                <field name="doc_type_id" invisible="item_category != 'document'" options="{'no_edit': True, 'no_create': True}"/>
                                                <field name="attachment_ids" widget="many2many_binary" invisible="not is_exhibit"/>
                                                <field name="create_date" string="Date &amp; Time Received"/>
                                            </group>
                                            <group>
                                                <field name="recovery_location"/>
                                                <field name="associated_with"/>
                                                <field name="storage_location"/>
                                                <field name="current_custodian"/>
                                                <field name="status"/>
                                                <field name="is_exhibit"/>
                                                <field name="last_movement_date"/>
                                            </group>
                                        </group>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="recom_action_list_view" model="ir.ui.view">
            <field name="name">recom.action.list</field>
            <field name="model">ed.action.line</field>
            <field name="arch" type="xml">
                <list create="0" duplicate="0">
                    <field name="recom_id" column_invisible="context.get('for_efs')"/>
                    <field name="gov_recom_id" column_invisible="not context.get('for_efs')"/>
                    <field name="user_id" domain="[('position','=','ed')]"/>
                    <field name="action_by"/>
                    <field name="action_date"/>
                    <field name="action" widget="radio" options="{'horizontal':True}"/>
                    <field name="status"/>
                    <button
                        name="action_mark_as_done"
                        string="Mark as Done"
                        class="btn-primary"
                        type="object"
                        invisible="status in ['pending']
                            or action != 'action'
                            or not is_lead_investigator
                            or is_complete"
                        />
                </list>
            </field>
        </record>
        <record id="recom_action_form_view" model="ir.ui.view">
            <field name="name">recom.action.list</field>
            <field name="model">ed.action.line</field>
            <field name="arch" type="xml">
                <form delete="0" create="0" duplicate="0">
                    <header>
                        <button
                                name="action_submit_feedback"
                                string="Submit Feedback"
                                class="btn-primary"
                                type="object"
                                invisible="status not in ['pending']
                                    or action != 'action'
                                    or not is_gov_user"
                        />
                        <button
                                name="action_mark_as_done"
                                string="Mark as Done"
                                class="btn-primary"
                                type="object"
                                invisible="status in ['pending']
                                    or action != 'action'
                                    or not is_lead_investigator
                                    or is_complete"
                        />
                        <field name="status" widget="statusbar" invisible="action != 'action'"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="recom_id" invisible="for_efs" readonly="1" options="{'no_open': True}"/>
                                <field name="gov_recom_id" invisible="not for_efs" readonly="1" options="{'no_open': True}"/>
                                <field name="user_id" domain="[('position','=','ed')]" readonly="1" options="{'no_open': True}"/>
                                <field name="action_by" readonly="1"/>
                                <field name="action_date" readonly="1"/>
                            </group>
                            <group>
                                <field name="action" widget="radio" options="{'horizontal':True}" readonly="1"/>
                                <field name="attachment_ids" widget="many2many_binary" readonly="1"/>
                                <field name="for_efs" invisible="1"/>
                                <field name="is_lead_investigator" invisible="1"/>
                                <field name="is_close" invisible="1"/>
                                <field name="is_gov_user" invisible="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="remark" placeholder="e.g. Documents verified, pending final approval." readonly="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

    </data>
</odoo>