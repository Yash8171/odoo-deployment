<odoo>
    <data>
        <!--Pop up View-->
        <record id="directorate_department_wizard_view_form" model="ir.ui.view">
            <field name="name">investigation.directorate.department.wizard.form</field>
            <field name="model">inv.dir.dept</field>
            <field name="arch" type="xml">
                <form create="0" duplicate="0">
                    <sheet>
                        <group>
                            <field name="directorate_id" required="1"
                                widget="selection_badge"/>
                            <field name="department_id" required="1"
                                domain="[('directorate_ids','in', directorate_id)]" widget="selection_badge"/>
                            <field name="investigation_id" invisible="1"/>
                            <field name="display_name" invisible="1"/>
                            <field name="color" invisible="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
 
        <record id="directorate_department_wizard_action" model="ir.actions.act_window">
            <field name="name">Investigation Directorate Department</field>
            <field name="res_model">inv.dir.dept</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="directorate_department_wizard_view_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
 