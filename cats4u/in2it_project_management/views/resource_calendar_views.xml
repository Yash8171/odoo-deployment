<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- menu of Working schedule in Employee -->
        <record id="hr.menu_resource_calendar_view" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [
                ref('base.group_system'),ref('in2it_forensic_services.group_fcm_admin')
            ])]"/>
        </record>

        <record id="in2it_view_form_resource_calendar_form_inherit" model="ir.ui.view">
            <field name="name">in2it.resource.calendar.form.inherit</field>
            <field name="model">resource.calendar</field>
            <field name="inherit_id" ref="resource.resource_calendar_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='%(resource.resource_calendar_leaves_action_from_calendar)d']" position="before">
                    <button name="action_public_holdays" type="object" icon="fa-sun-o" class="oe_stat_button">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_text">
                            <field name="associated_leaves_count"/> Public
                        </span>
                        <span class="o_stat_text">
                            Time Off
                        </span>
                        </div>
                    </button>
                </xpath>

                <xpath expr="//button[@name='%(resource.resource_calendar_leaves_action_from_calendar)d']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>