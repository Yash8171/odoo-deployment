<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <record id="view_overarching_memo_list" model="ir.ui.view">
            <field name="name">Overarching Memo List</field>
            <field name="model">overarching.memo</field>
            <field name="arch" type="xml">
                <list create="0">
                    <field name="name"/>
                    <field name="project_id" string="Case Id"/>
                    <field name="status" widget="badge" decoration-warning="status == 'pending'" decoration-success="status == 'approved'"/>
                </list>
            </field>
        </record>

        <record id="view_overarching_memo_form" model="ir.ui.view">
            <field name="name">Overarching Memo Form</field>
            <field name="model">overarching.memo</field>
            <field name="arch" type="xml">
                <form create="0">
                    <header>
                        <field name="status" widget="statusbar"/>
                        <button name="action_preview_investigation_report" class="btn-primary" string="Preview Investigation Report" icon="fa-eye" type="object" invisible="assignment_type != 'internal' or case_type == 'pre'"/>

                        <button
                            name="generate_preliminary_assessment_report"
                            class="btn btn-primary"
                            string="Assessment Report"
                            type="object"
                            icon="fa-file"
                            invisible="assignment_type != 'internal' or case_type != 'pre'"/>
                        <button name="action_approve_by_city_manager" class="btn btn-primary" string="Approve" type="object"  invisible="memo_pending_at != 'city_manager' or uid != city_manager_id"/>

                        <button name="action_request_change_by_city_manager" class="btn btn-primary" string="Request Change" type="object"  invisible="memo_pending_at != 'city_manager' or uid != city_manager_id"/>
                        <button name="action_submit_by_lead_investigator" class="btn btn-primary" string="Edit &amp; Send Letter(CM)" type="object"  invisible="memo_pending_at != 'lead_investigator' or uid not in lead_investigator_ids"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="investigator_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                                <field name="lead_investigator_ids" widget="many2many_tags" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                                <field name="approval_date" readonly="1"/>
                                <field name="remark" readonly="1"/>
                                <field name="memo_pending_at" readonly="1" invisible="status == 'approved'"/>
                                <field name="city_manager_id" invisible="1" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                                <field name="request_change" string="Required Change" readonly="1" invisible="not request_change"/>
                            </group>
                            <group>
                                <field name="project_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}" string="Case Id"/>
                                <field name="case_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}" invisible="1"/>
                                <field name="directorate_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                                <field name="allegation_nature_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                                <field name="case_type" readonly="1"/>
                                <field name="assignment_type" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Attachments" name="Attachments" invisible="not attachment_ids">
                                <field name="attachment_ids" widget="many2many_binary" readonly="1">
                                    <kanban>
                                        <templates>
                                            <t t-name="card">
                                                <div class="o_kanban_card">
                                                    <field name="name"/>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                            <page string="Exhibit" name="exhibit">
                                <div class="row">
                                    <group string="Physical Items Received">
                                        <field name="physical_item_ids" nolabel="1" readonly="1">
                                            <list>
                                                <field name="sequence" widget="handle"/>
                                                <field name="id" optional="hide"/>
                                                <field name="item_title" required="1"/>
                                                <field name="item_category" optional="show" required="1"/>
                                                <field name="quantity" optional="show" required="1"/>
                                                <field name="uom_id" optional="show" required="1"
                                                        options="{'no_edit': True, 'no_create': True}"/>
                                                <field name="create_date" optional="hide"
                                                        string="Date &amp; Time Received"/>
                                                <field name="source" optional="hide"/>
                                                <field name="recovery_location" optional="show" required="1"/>
                                                <field name="associated_with" optional="hide" required="1"/>
                                                <field name="storage_location" optional="show" required="1"/>
                                                <field name="current_custodian" optional="hide"/>
                                                <field name="status" optional="show" required="1"/>
                                                <field name="last_movement_date" optional="hide" force_save="1"/>
                                                <field name="doc_type_id" optional="show"  options="{'no_edit': True, 'no_create': True}"/>
                                                <field name="attachment_ids" optional="show" widget="many2many_binary"/>
                                                <field name="is_exhibit" widget="boolean_toggle" column_invisible="1"/>
                                            </list>
                                            <form>
                                                <group>
                                                    <group>
                                                        <field name="item_title"/>
                                                        <field name="item_category"/>
                                                        <field name="quantity"/>
                                                        <field name="uom_id"
                                                                options="{'no_open': True, 'no_edit': True, 'no_create': True}"/>
                                                        <field name="source"/>
                                                        <field name="doc_type_id"  invisible="item_category != 'document'" options="{'no_open': True, 'no_edit': True, 'no_create': True}"/>
                                                        <field name="attachment_ids" widget="many2many_binary" invisible="not is_exhibit"/>
                                                        <field name="create_date" string="Date &amp; Time Received"/>
                                                    </group>
                                                    <group>
                                                        <field name="recovery_location"/>
                                                        <field name="associated_with"/>
                                                        <field name="storage_location"/>
                                                        <field name="current_custodian"  options="{'no_open': True, 'no_create': True, 'no_edit': True}" />
                                                        <field name="status"/>
                                                        <field name="is_exhibit"/>
                                                        <field name="last_movement_date"/>
                                                    </group>
                                                </group>
                                            </form>
                                        </field>
                                    </group>
                                </div>
                            </page>

                            <!-- ===== DOCUMENTATION TAB ===== -->
                            <page string="Annexure" name="annexure">
                                <field name="document_line_ids" readonly="1">
                                    <list>
                                        <field name="serial_no"/>
                                        <field name="description"/>
                                        <field name="document_type_id"/>
                                        <field name="file_name"/>
                                        <field name="uploaded_by"/>
                                        <field name="uploaded_date"/>
                                        <field name="document_stores"/>
                                        <field name="document_stores_location"/>
                                        <field name="is_annexure" widget="boolean_toggle" column_invisible="1"/>
                                        <control><create name="add_a_document" string="Add a document"/></control>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="serial_no"/>
                                                    <field name="file" filename="file_name" widget="binary"/>
                                                    <field name="file_name" invisible="1"/>
                                                    <field name="document_type_id" options="{'no_create':True, 'no_edit':True, 'no_open':True}"/>
                                                    <field name="is_annexure"/>
                                                    <field name="document_stores"/>
                                                    <field name="document_stores_location" invisible="not document_stores"/>
                                                </group>
                                                <group>
                                                    <field name="description"/>
                                                    <field name="obtained_by"/>
                                                    <field name="obtained_from" options="{'no_create':True, 'no_edit':True, 'no_open':True}"/>
                                                    <field name="obtained_date"/>
                                                    <field name="uploaded_by"  options="{'no_create':True, 'no_edit':True, 'no_open':True}"/>
                                                    <field name="uploaded_date"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Distribution List">
                                <field name="distribution_line_ids" readonly="1">
                                    <list>
                                        <field name="user_id"/>
                                        <field name="status"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="search_view_overarching_memo" model="ir.ui.view">
            <field name="name">overarching.memo.search</field>
            <field name="model">overarching.memo</field>
            <field name="arch" type="xml">
                <search string="Overarching Memo Search">
                    <!-- Basic search fields -->
                    <field name="status"/>

                    <!-- Filter for Pending -->
                    <filter name="pending" string="Pending" domain="[('status','=','pending')]"/>

                    <!-- Optional: other filters -->
                    <filter name="completed" string="Completed" domain="[('status','=','approved')]"/>
                </search>
            </field>
        </record>

        <!-- Overarching Memo action -->
        <record id="overarching_memo_action" model="ir.actions.act_window">
            <field name="name">Overarching Memo</field>
            <field name="res_model">overarching.memo</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('view_overarching_memo_list')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_overarching_memo_form')})]"/>
            <!-- <field name="context">{'search_default_pending': 1}</field> -->
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    There are no items pending your approval.
                </p>
            </field>
        </record>

        <record id="action_overarching_memo_action" model="ir.actions.server">
          <field name="name">Overarching Memo Action</field>
          <field name="model_id" ref="in2it_project_management.model_overarching_memo"/>
          <field name="binding_model_id" ref="in2it_project_management.model_overarching_memo"/>
          <field name="state">code</field>
          <field name="code">action = model.get_overarching_memo()</field>
        </record>

        <menuitem
                id="overarching_memo_menu"
                name="Overarching Memo "
                parent="project.menu_main_pm"
                action="in2it_project_management.action_overarching_memo_action"
                groups="in2it_forensic_services.group_fcm_city_manager,base.group_system,in2it_forensic_services.group_fcm_admin"
                sequence="6"/>
    </data>
</odoo>