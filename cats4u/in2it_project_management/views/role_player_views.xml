<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_role_player_tree" model="ir.ui.view">
        <field name="name">role.player.tree</field>
        <field name="model">role.player.abbreviation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
                <field name="is_seeded"/>
            </list>
        </field>
    </record>

    <record id="view_role_player_form" model="ir.ui.view">
        <field name="name">role.player.form</field>
        <field name="model">role.player.abbreviation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="is_seeded"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_role_player" model="ir.actions.act_window">
        <field name="name">Role Player</field>
        <field name="res_model">role.player.abbreviation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_role_player"
              name="Role Player &amp; Abbreviation"
              parent="project.menu_project_config"
              action="action_role_player"/>
</odoo>
