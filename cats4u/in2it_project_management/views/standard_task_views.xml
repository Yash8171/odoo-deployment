<odoo>
    <data>
        <record id="standard_tasks_view_tree" model="ir.ui.view">
            <field name="name">standard.task.tree</field>
            <field name="model">standard.task</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="task_category_id"/>
                </list>
            </field>
        </record>
 
        <record id="standard_tasks_view_form" model="ir.ui.view">
            <field name="name">standard.task.form</field>
            <field name="model">standard.task</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" placeholder="e.g. Investigation plan"/>
                                <field name="task_category_id" required="1"/>
                                <field name="task_details"/>
                            </group>
                            <group>
                                <field name="is_sla" widget="radio" options="{'horizontal':True}"/>
                                <field name="sla_days" invisible="is_sla == 'no'"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
 
        <record id="action_standard_tasks_menu" model="ir.actions.act_window">
            <field name="name">Standard Task</field>
            <field name="res_model">standard.task</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_standard_task_category_menu" model="ir.actions.act_window">
            <field name="name">Standard Task Category</field>
            <field name="res_model">standard.task.category</field>
            <field name="view_mode">list,form</field>
        </record>
 
        <menuitem id="standard_tasks_action_menu"
                  name="Standard Tasks"
                  action="action_standard_tasks_menu"
                  parent="project.menu_project_config"
                  sequence="100"/>



        <menuitem id="standard_tasks_category_action_menu"
                  name="Standard Task Category"
                  action="action_standard_task_category_menu"
                  parent="project.menu_project_config"
                  sequence="99"/>
    
    </data>
</odoo>
 