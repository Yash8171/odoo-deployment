<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
           <record id="project.menu_main_pm" model="ir.ui.menu">
                <field name="name">Case Investigation</field>
                <field name="groups_id" eval="[(4,
                ref('in2it_forensic_services.group_fcm_city_manager'))]"/>
           </record>

            <record id="project.menu_projects" model="ir.ui.menu">
                <field name="name">Case Investigation</field>
                <field name="groups_id" eval="[
                (4, ref('project.group_project_user')),
                (4, ref('project.group_project_manager'))
                ]"/>
            </record>

            <record id="project.menu_projects_group_stage" model="ir.ui.menu">
                <field name="name">Case Investigation</field>
                <field name="groups_id" eval="[(6, 0, [
                ref('project.group_project_user'),
                ref('project.group_project_manager')
                ])]"/>
            </record>

            <record id="project.menu_project_management" model="ir.ui.menu">
              <field name="groups_id" eval="[
              (4, ref('project.group_project_user')),
              (4, ref('project.group_project_manager'))
               ]"/>
            </record>


        <menuitem 
            id="recommendation_category_action_menu"
            name="Category"
            action="action_recommendation_category_menu"
            parent="project.menu_project_config"
            sequence="110"/>

        <record id="project.menu_project_config" model="ir.ui.menu">
          <field name="groups_id" eval="[(4,
              ref('in2it_forensic_services.group_fcm_admin'))]"/>
        </record>

        <record id="action_project_recommendation_category" model="ir.actions.act_window">
            <field name="name">Investigation Recommendations</field>
            <field name="res_model">project.category</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'group_by': 'project_id','default_status':'in_progress', 'create':True}</field>
            <field name="domain">[('memo_status','in',['approved'])]</field>
        </record>

        <menuitem 
            id="project_recommendation_category_menu"
            name="Recommendations"
            action="action_project_recommendation_category"
            parent="project.menu_project_management"
            sequence="1"/>

    </data>
</odoo>