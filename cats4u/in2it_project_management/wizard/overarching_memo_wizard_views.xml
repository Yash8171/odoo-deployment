<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- wizard of overarching.memo.wizard-->
        <record id="request_overarching_memo_wizard_form_view" model="ir.ui.view">
            <field name="name">overarching.memo.wizard.form.view</field>
            <field name="model">overarching.memo.wizard</field>
            <field name="arch" type="xml">
                <form string="Overarching Memo">
                    <sheet>
                        <group>
                            <field name="project_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                            <field name="case_type" readonly="1"/>
                            <field name="directorate_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                            <field name="allegation_nature_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                            <field name="investigator_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                            <field name="lead_investigator_ids" widget="many2many_tags" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                            <field name="approval_date" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                            <field name="remark" required="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" data-hotkey="q"/>
                        <button special="cancel" string="Cancel" class="btn btn-danger"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
