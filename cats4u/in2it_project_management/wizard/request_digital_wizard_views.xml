<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- wizard of request.access.digital.wizard-->
        <record id="request_digital_wizard_form_view" model="ir.ui.view">
            <field name="name">request.digital.wizard.form.view</field>
            <field name="model">request.digital.wizard</field>
            <field name="arch" type="xml">
                <form string="Digital Request">
                    <sheet>
                        <group>
                            <field name="project_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_edit': True}" invisible="1"/>
                            <field name="suspect_ids" domain="[('id','in',context.get('suspects',[]))]" widget="many2many_tags" options="{'no_open': True, 'no_create': True, 'no_edit': True}" required="1"/>
                            <field name="date_from" required="1" widget="daterange" options="{'end_date_field': 'date_to'}"/>
                            <field name="date_to" required="1" invisible="1"/>
                            <field name="evidence" required="1"/>
                            <field name="comment" required="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" data-hotkey="q"/>
                        <button special="cancel" string="Cancel" class="btn btn-danger"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
