<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_peer_review_signoff_wizard_form" model="ir.ui.view">
            <field name="name">peer.review.signoff.wizard.form</field>
            <field name="model">peer.review.signoff.wizard</field>
            <field name="arch" type="xml">
                <form string="Sign Off Review">
                    <group>
                        <field name="attachment_ids" widget="many2many_binary" required="1"/>

                        <field name="signature"
                               widget="signature"
                               required="1"/>
                    </group>

                    <footer>
                        <button name="action_submit"
                                type="object"
                                string="Submit"
                                class="btn-primary"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>

                </form>
            </field>
        </record>

    </data>
</odoo>