<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_peer_review_change_wizard_form" model="ir.ui.view">
            <field name="name">peer.review.change.wizard.form</field>
            <field name="model">peer.review.change.wizard</field>
            <field name="arch" type="xml">
                <form string="Changes Required">

                    <group>
                        <field name="comment"/>
                    </group>

                    <footer>
                        <button name="action_submit"
                                type="object"
                                string="Submit"
                                class="btn-primary"/>

                        <button string="Cancel"
                                special="cancel"
                                class="btn-secondary"/>
                    </footer>

                </form>
            </field>
        </record>

    </data>
</odoo>