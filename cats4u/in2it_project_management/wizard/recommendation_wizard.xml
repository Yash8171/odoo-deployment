<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="view_recom_submit_feedback_wizard_form" model="ir.ui.view">
            <field name="name">recom.submit.feedback.wizard.form</field>
            <field name="model">recom.submit.feedback.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                            <field name="attachment_ids" widget="many2many_binary" required="1"/>
                            </group>
                            <group>
                                <field name="status" required="1"/>
                                <field name="recom_action_id" invisible="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="remark" required="1" placeholder="e.g. Documents verified, pending final approval."/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_Submit" string="Submit" class="btn-primary" type="object"/>
                        <button special="cancel" string="Cancel" class="btn-danger"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>