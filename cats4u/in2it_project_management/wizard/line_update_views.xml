<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="view_comment_wizard_form" model="ir.ui.view">
            <field name="name">comment.wizard.form</field>
            <field name="model">comment.wizard</field>
            <field name="arch" type="xml">
                <form string="Add Comment">
                    <group>
                        <field name="comment"/>
                    </group>
                    <footer>
                        <button name="action_submit_comment"
                                string="Send"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel"
                                special="cancel"
                                class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>