<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!--  Planing Report  -->
    <template id="in2it_cms_investigation_planning_report_temp">
      <t t-call="web.html_container">
            <t t-call="web.external_layout">
              <main style="font-family:sans-serif; font-size:13px;">
                <div class="page">
                  <ul class="list-unstyled" style="padding-left: 0; margin-left: 0;">
                    <li>
                        <strong>Generated on:</strong>
                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                    </li>
                    <li>
                        <strong>Generated by:</strong>
                        <t t-esc="user.name"/>
                    </li>
                  </ul>
                  <br/>
                  <h4 style="color:#004466;" class="text-center"><strong>Investigation Planning Report</strong></h4>
                  <br/>
                  <t t-foreach="docs" t-as="doc">
                    <t t-if="doc.task_ids">
                        <h5 style="color:#004466;"><strong>Investigation Details:</strong></h5>
                        <div class="row border border-black" style="border-radius:5px;">
                          <div class="col-6" style="padding:5px;">
                            <ul class="list-unstyled" style="padding-left: 0; margin-left: 0; margin-bottom:0;">
                              <li>
                                <strong>Reference no :</strong>
                                <t t-esc="doc.name"/>
                              </li>
                              <li>
                                <strong>Investigation Manager :</strong>
                                <t t-esc="doc.user_id.name"/>
                              </li>
                              <li>
                                <strong>Chief :</strong>
                                <t t-esc="doc.chief_id.name"/>
                              </li>
                              <li>
                                <strong>Directorate :</strong>
                                <t t-esc="doc.directorate_id.name"/>
                              </li>
                              <li>
                                <strong>Department :</strong>
                                <t t-esc="doc.department_id.name"/>
                              </li>
                            </ul>
                          </div>

                          <div class="col-6" style="padding:5px; border-left:1px solid black;">
                            <ul class="list-unstyled" style="padding-left: 0; margin-left: 0; margin-bottom:0;">
                              <li>
                                <strong>Case :</strong>
                                <t t-esc="doc.case_id.internal_coms_ref"/>
                              </li>

                              <li>
                                <strong>Complainant:</strong>
                                <t t-esc="doc.partner_id.name"/>
                              </li>
                              <li>
                                <strong>Approval Status:</strong>
                                <t t-esc="doc.approval_status"/>
                              </li>
                              <li class="row">
                                <strong>Planned Date:</strong>
                                <span>
                                  <t t-if="doc.date_start">
                                    <t t-esc="doc.date_start.strftime('%Y-%m-%d')"/>
                                  </t>
                                  <t t-if="doc.date">-
                                    <t t-esc="doc.date.strftime('%Y-%m-%d')"/>
                                  </t>
                                </span>
                              </li>
                              <li>
                                <strong>Authorization Date</strong>
                                <t t-esc="doc.create_date.strftime('%Y-%m-%d')"/>
                              </li>
                            </ul>
                          </div>
                        </div>
                        <br/>
                        <br/>
                        <h5 style="color:#004466; line-height:1px;"><strong>Investigation Plan:</strong></h5>
                        <table class="table table-striped mt-4">
                          <thead class="border border-black">
                            <tr style="text-align:center; font-weight:bold; background-color:#e6e6e6;">
                              <th class="fw-bold">Title</th>
                              <th class="fw-bold">Investigator</th>
                              <th class="fw-bold">Approved By</th>
                              <th class="fw-bold">Deadline</th>
                              <th class="fw-bold">Completion Date</th>
                              <th class="fw-bold">Estimate</th>
                              <th class="fw-bold">Status</th>
                            </tr>
                          </thead>
                          <tbody>
                            <t t-foreach="doc.task_ids" t-as="task">
                              <tr>
                                <td><t t-esc="task.name"/></td>

                                <td>
                                  <t t-if="task.user_ids">
                                    <t t-set="assignees" t-value="task.sudo().user_ids"/>
                                    <t t-foreach="assignees" t-as="user">
                                      <div>
                                          <t t-esc="user.name"/>
                                      </div>
                                    </t>
                                  </t>
                                </td>

                                <td><t t-esc="task.approved_by_id.name"/></td>

                                <td>
                                  <t t-if="task.date_deadline">
                                    <t t-esc="task.date_deadline.strftime('%Y-%m-%d')"/>
                                  </t>
                                </td>

                                <td>
                                  <t t-if="task.actual_completion_date">
                                    <t t-esc="task.actual_completion_date.strftime('%Y-%m-%d')"/>
                                  </t>
                                </td>

                                <td><t t-esc="task.allocated_hours"/></td>
                                <td><t t-esc="task.stage_id.name"/></td>
                              </tr>
                            </t>
                          </tbody>
                        </table>
                        <br/>
                        <br/>
                      <div style="page-break-after: always;"/>
                    </t>
                  </t>
                </div>
              </main>

            </t>
          </t>
    </template>

    <record id="action_cms_investigation_planning_report" model="ir.actions.report">
      <field name="name">Planning Report</field>
      <field name="model">project.project</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">in2it_project_management.in2it_cms_investigation_planning_report_temp</field>
      <field name="report_file">in2it_project_management.in2it_cms_investigation_planning_report_temp</field>
      <field name="binding_model_id" ref="model_project_project"/>
      <field name="binding_type">report</field>
    </record>
  </data>
</odoo>