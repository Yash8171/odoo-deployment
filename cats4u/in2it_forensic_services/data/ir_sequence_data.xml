<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

<!--        COM Sequence-->
        <record id="seq_forensic_com_case" model="ir.sequence">
            <field name="name">Forensic COM Case</field>
            <field name="code">forensic.com.case</field>
            <field name="padding">3</field>
            <field name="prefix">EFS/COM/</field>
            <field name="number_next">1</field>
        </record>

        <!-- Serial Number -->
        <record id="seq_forensic_document_line" model="ir.sequence">
            <field name="name">Forensic Document</field>
            <field name="code">forensic.document.line</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
        </record>
    </data>
</odoo>
