<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="common_stage_reviewed" model="forensic.assignment.stage">
            <field name="name">ReCom Review</field>
            <field name="is_common_stage">True</field>
            <field name="is_under_review">True</field>
            <field name="sequence">35</field>
        </record>

        <record id="common_stage_case_intake" model="forensic.assignment.stage">
            <field name="name">Case Intake</field>
            <field name="is_common_stage">True</field>
            <field name="sequence">20</field>
        </record>

        <record id="common_stage_under_review" model="forensic.assignment.stage">
            <field name="name">Under Review</field>
            <field name="is_common_stage">True</field>
            <field name="sequence">30</field>
        </record>
        

        <record id="case_type_stage_under_authorisation" model="forensic.assignment.stage">
            <field name="name">Under Authorization</field>
            <field name="sequence">40</field>
        </record>

        <record id="case_type_stage_authorised" model="forensic.assignment.stage">
            <field name="name">Planning</field>
            <field name="sequence">43</field>
        </record>


        <record id="case_type_stage_reject" model="forensic.assignment.stage">
            <field name="name">Unauthorised</field>
            <field name="sequence">120</field>
        </record>

        <record id="case_type_stage_closed" model="forensic.assignment.stage">
            <field name="name">Closed</field>
            <field name="is_last">True</field>
            <field name="sequence">100</field>
        </record>

        <record id="case_type_stage_assigned_to_directorate" model="forensic.assignment.stage">
            <field name="name">Assigned to Directorate</field>
            <field name="sequence">50</field>
        </record>


    </data>
</odoo>
