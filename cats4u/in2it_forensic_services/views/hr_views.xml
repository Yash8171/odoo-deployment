<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_dept_inherit_case_mgt" model="ir.ui.view">
        <field name="name">hr.dept.form.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_employee_from_department']" position="before">
                    <button name="action_view_jobs" type="object" class="oe_stat_button" icon="fa-briefcase">
                        <field name="job_count" widget="statinfo" string="Jobs"/>
                    </button>
            </xpath>

            <xpath expr="//field[@name='color']" position="after">
                <field name="is_forensic_dep"/>
            </xpath>


        </field>
    </record>

        <!--Inherit HR Job Tree-->
    <record id="view_hr_job_inherit_list_case_mgt" model="ir.ui.view">
        <field name="name">hr.job.tree.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="unit_ids" widget="many2many_tags" optional="show"/>
            </xpath>
        </field>
    </record>

    <!--Inherit HR Job Form-->
    <record id="view_hr_job_inherit_case_mgt" model="ir.ui.view">
        <field name="name">hr.job.form.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                    <group>
                        <field name="unit_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True, 'no_edit': True}"/>
                        <field name="job_desc"/>
                    </group>
            </xpath>
        </field>
    </record>

    <!--    Employee form-->
    <record id="hr_employee_form_case_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.case.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='coach_id']" position="after">
                <field name="origin_type"/>
            </xpath>

            <xpath expr="//field[@name='work_email']" position="attributes">
                <attribute name="required">1</attribute>
                <attribute name="string">Email</attribute>
            </xpath>

            <xpath expr="//field[@name='work_phone']" position="attributes">
                <attribute name="required">1</attribute>
                <attribute name="string">Telephone</attribute>
            </xpath>

            <xpath expr="//field[@name='mobile_phone']" position="attributes">
                <attribute name="required">1</attribute>
                <attribute name="string">Mobile</attribute>
            </xpath>

        </field>
    </record>
</odoo>