    <record id="view_res_partner_form_inherit_case_mgt" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.suspect</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook/page[@name='contact_addresses']" position="before">
                <page string="Case Information" name="case_info" autofocus="autofocus">
                    <group string="Forensic Case Information" name="suspect_info_group">
                        <field name="is_anonymous" widget="boolean_toggle"/>
                        <field name="is_complainant" widget="boolean_toggle"/>
                    </group>
                    <group string="Associated Cases as Complainant">
                        <field name="complainant_case_ids" nolabel="1" readonly="0" mode="list"
                               context="{'default_view_mode': 'list','list_view_ref': 'in2it_forensic_services.view_crm_lead_forensic_list_custom'}">
                            <list string="Case Management">
                                <field name="internal_coms_ref"/>
                                <field name="name" string="Case Title" optional="hide"/>
                                <field name="assignment_type_ids" widget="many2many_tags" optional="hide"/>
                                <field name="directorate_id" optional="show"/>
                                <field name="department_id" optional="show"/>
                                <field name="active" optional="hide"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

