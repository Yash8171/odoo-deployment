<odoo>
    <record id="view_case_memo_wizard_form" model="ir.ui.view">
        <field name="name">casetype.authorize.wizard.form</field>
        <field name="model">casetype.authorize.wizard</field>
        <field name="arch" type="xml">
            <form string="Memo Creator">
                <group>
                    <!-- <field name="case_type_id"/> -->
                    <field name="user_id"
                        placeholder="Add contacts to notify..."
                        options="{'no_quick_create': True,'no_create':True}"
                        required="1"
                        domain="[('id','in',context.get('users',[]))]"/>
                    <field name="subject" decoration-bf="1"/>
                    <field name="auth_body" widget="html"/>
                    <field name="attachment_ids" widget="mail_composer_attachment_list"/>
                    <field name="model" invisible="1"/>
                    <field name="res_ids" invisible="1"/>

                </group>
                <footer>
                    <button string="Send Mail"
                            name="action_send_mail"
                            type="object"
                            class="btn-primary"/>
                            
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                    <field name="attachment_ids" widget="mail_composer_attachment_selector"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>