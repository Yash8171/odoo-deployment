<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="forensic_case_revise_wizard_form" model="ir.ui.view">
        <field name="name">forensic.case.revise.wizard.form</field>
        <field name="model">forensic.case.revise.wizard</field>
        <field name="arch" type="xml">
            <form string="Revise Case">
                <group>
                    <field name="lead_id" invisible="1"/>
                    <field name="note" placeholder="Write your note here..." required="1"/>
                    <field name="owner_id" invisible="0" string="Assigned To" options="{'no_open': True, 'no_edit': True, 'no_create': True}"/>
                </group>

                <footer>
                    <button string="Submit"
                            type="object"
                            name="action_submit"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
