<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_case_assignment_transient_form" model="ir.ui.view">
        <field name="name">case.assignment.transient.form</field>
        <field name="model">case.assignment.transient</field>
        <field name="arch" type="xml">
            <form>
                <group>

                    <field name="case_id" invisible="1"/>
                    <field name="assignment_type_ids" widget="many2many_tags"
                           domain="[('id', 'in', context.get('assigned_types', []))]"
                           invisible="context.get('reject_case')" required="context.get('assign_case')"
                           options="{'no_create':True, 'no_open':True, 'no_create_edit':True}"/>
                    <field name="note" placeholder="Comment" required="context.get('reject_case')"/>
                </group>
                <footer>
                    <button string="Request Authorization" name="action_case_assign" type="object" class="oe_highlight"
                            invisible="not context.get('assign_case')" data-hotkey="s"/>
                    <button string="Reject" name="action_case_close" type="object" class="oe_highlight"
                            invisible="not context.get('reject_case')" data-hotkey="c"/>
                    <button string="Send" name="action_send_classification_request" type="object" class="oe_highlight"
                            invisible="not context.get('classification_request')" data-hotkey="d"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
