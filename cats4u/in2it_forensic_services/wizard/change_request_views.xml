<odoo>
    <record id="view_change_request_wizard_form" model="ir.ui.view">
        <field name="name">change.request.wizard.form</field>
        <field name="model">change.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Request">
                <group>
                   <field name="assignment_type_ids"
                    widget="many2many_tags" 
                    options="{'no_create':True, 'no_open':True, 'no_create_edit':True}"/>
                   <field name="comment"/>
                </group>
                <footer>
                    <button string="Change Request"
                            name="action_change_request"
                            type="object"
                            class="btn-primary"
                            confirm="Are you sure want to change this request ?"/>
                            
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="popup_wizard_form_view" model="ir.ui.view">
        <field name="name">popup.wizard.form</field>
        <field name="model">popup.wizard</field>
        <field name="arch" type="xml">
            <form string="Submission Successful">
                <group>
                    <field name="message" widget="html" nolabel="1"/>
                </group>

                <footer>
                    <button string="OK" special="cancel" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>