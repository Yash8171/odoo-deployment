<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- List View : system.notification -->
        <record id="notification_model_view_tree" model="ir.ui.view">
            <field name="name">system.notification.tree</field>
            <field name="model">system.notification</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="message" />
                    <field name="user_id" />
                    <field name="state" />
                </list>
            </field>
        </record>
        
        
        <!-- Form View : system.notification-->
        <record id="notification_model_view_form" model="ir.ui.view">
            <field name="name">system.notification.form</field>
            <field name="model">system.notification</field>
            <field name="arch" type="xml">
                <form string="SystemNotification">
                    <sheet>
                        <group>
                            <div>
                                <label class="o_form_label" for="message" string="Message"/>
                            </div>
                            <div style="margin-top:5px padding:10px;">
                                <h1><field name="message"/></h1>
                            </div>
                            <field name="user_id" />
                            <field name="res_model" invisible="1" />
                            <field name="res_model_id" options="{'no_quick_create': True, 'no_create_edit' : True}" />
                            <field name="res_id" />
                            <field name="state" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="notification_model_action" model="ir.actions.act_window">
            <field name="name">Sys Notification</field>
            <field name="res_model">system.notification</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu -->
        <menuitem id="notification_menu_root" name="System Notification" sequence="10" groups="base.group_system"/>
        
        <menuitem id="notification_menu" name="Notification" parent="notification_menu_root" action="notification_model_action" sequence="10"/>
        
        

    </data>
</odoo>
